# ─────────────────────────────────────────────────────────────────────────────
# HAPM — HAProxy Manager
# .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─── Secrets & Config ────────────────────────────────────────────────────────
.env
*.env.local
*.env.production
*.env.staging

# ─── Build output ────────────────────────────────────────────────────────────
/bin/
/hapm
/hapm-acme
/hapm-linux-amd64
/hapm-linux-arm64
nohup.out

# ─── Database files ──────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
/data/

# ─── Go ──────────────────────────────────────────────────────────────────────
# Test coverage
coverage.out
coverage.html

# Air (hot reload tool) temp files
tmp/
.air.toml

# Vendor directory (kita pakai go mod)
vendor/

# ─── IDE & Editor ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── SSL Certificates (jangan commit certs real) ─────────────────────────────
*.pem
*.crt
*.key
*.p12
*.pfx
certs/

# ─── LEGO ACME accounts (berisi private key account LE) ──────────────────────
.lego/

# ─── Docker ──────────────────────────────────────────────────────────────────
# File docker-compose override untuk local dev
docker-compose.override.yml
docker-compose.local.yml
