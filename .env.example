# ─────────────────────────────────────────────────────────────────────────────
# HAPM — HAProxy Manager
# Salin file ini ke .env dan isi nilai yang sesuai
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── Aplikasi ────────────────────────────────────────────────────────────────
APP_NAME="HAProxy Manager"
APP_MODE=production
APP_PORT=8282
APP_BASE_URL=http://localhost:8282

# Mode proxy: direct | proxy | cloudflare
APP_PROXY_MODE=direct


# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate dengan: openssl rand -hex 32
APP_JWT_ACCESS_SECRET=GANTI_DENGAN_SECRET_64_KARAKTER_HEX
APP_JWT_REFRESH_SECRET=GANTI_DENGAN_SECRET_64_KARAKTER_HEX_LAIN

APP_JWT_ACCESS_EXPIRY=15m
APP_JWT_REFRESH_EXPIRY=168h

# ─── Security (Enkripsi SSH Keys) ────────────────────────────────────────────
# Generate dengan: openssl rand -hex 32
APP_ENCRYPTION_KEY=GANTI_DENGAN_KEY_64_KARAKTER_HEX

# ─── Rate Limiting ────────────────────────────────────────────────────────────
APP_RATE_LIMIT_LOGIN=5
APP_RATE_LIMIT_LOGIN_WINDOW=15
APP_RATE_LIMIT_API=120
APP_ACCOUNT_LOCKOUT_ATTEMPTS=5
APP_ACCOUNT_LOCKOUT_DURATION=30m

# ─── Logging ─────────────────────────────────────────────────────────────────
APP_LOG_LEVEL=info
APP_LOG_FORMAT=json

LEGO_DNS_DISABLE_CP=false
LEGO_DNS_RESOLVERS=8.8.8.8:53,1.1.1.1:53
LEGO_RETRY_MAX=2
LEGO_RETRY_WAIT=60

# ─── CMC (Certificate Management Center) ─────────────────────────────────────
CMC_ACME_SERVICE_URL=http://localhost:8889
